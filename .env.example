# ── Hermes Environment Configuration ────────────────────────────────────────
# Copy to .env and fill in real values before running.
#
# PRODUCTION CHECKLIST — all items marked [PROD] must be changed before deploy:
#   [ ] ENVIRONMENT=production
#   [ ] JWT_SECRET — generate: openssl rand -hex 32
#   [ ] POSTGRES_PASSWORD — strong random password
#   [ ] COOKIE_SECURE=true  (requires HTTPS)
#   [ ] FORCE_HTTPS=true
#   [ ] ALLOW_PRIVATE_DESTINATIONS=false
#   [ ] AUTO_CREATE_TABLES=false  (run: alembic upgrade head)
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Hermes Webhook Middleware
ENVIRONMENT=development              # [PROD] change to: production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hermes:hermesdev@localhost:5432/hermes
SYNC_DATABASE_URL=postgresql://hermes:hermesdev@localhost:5432/hermes
POSTGRES_PASSWORD=hermesdev          # [PROD] use a strong random password

# DB connection pool (production tuning)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL_SECONDS=1.0
DEFAULT_MAX_RETRIES=5
HTTP_CLIENT_TIMEOUT_SECONDS=10.0
BACKOFF_BASE_SECONDS=30

# ── Security ──────────────────────────────────────────────────────────────────
# [PROD] Generate with: openssl rand -hex 32  — NEVER use the default in production.
# The API will refuse to start in ENVIRONMENT=production with this placeholder.
JWT_SECRET=change-this-secret-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# [PROD] Must be true when running behind HTTPS
COOKIE_SECURE=false
COOKIE_DOMAIN=

# [PROD] Set to true in production — redirects HTTP → HTTPS
FORCE_HTTPS=false

# CORS — leave empty when frontend is co-served via nginx (same domain).
# Set to comma-separated origins when dashboard is on a different domain.
# Never use "*" — it is rejected by browsers when allow_credentials=True.
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# ── API Keys (legacy / programmatic access) ───────────────────────────────────
# Leave empty for local dev. Set in production for X-Hermes-API-Key auth.
HERMES_API_KEY=
# Multi-tenant key map: tenant_a:key_a,tenant_b:key_b
HERMES_API_KEYS=

# ── Destination validation ────────────────────────────────────────────────────
# [PROD] MUST be false — allows SSRF to internal IPs if true.
ALLOW_PRIVATE_DESTINATIONS=false
# Optional allowlist for extra restriction: api.example.com,webhooks.example.com
DESTINATION_HOST_ALLOWLIST=

# ── Webhook signature verification ───────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
HERMES_WEBHOOK_SECRET=
SIGNATURE_TOLERANCE_SECONDS=300

# Standard Webhooks outbound signing secret (whsec_ prefixed base64)
STANDARD_WEBHOOKS_SECRET=

# ── Rate limiting & quotas ────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
# Per-tenant monthly event quota. 0 = unlimited (default for self-hosted).
# Set a positive integer to enforce hard cutoff at ingestion (returns HTTP 429).
MONTHLY_EVENT_QUOTA=0

# ── Schema management ─────────────────────────────────────────────────────────
# [PROD] Always false — run: alembic upgrade head before starting the API.
AUTO_CREATE_TABLES=false

# ── Observability ─────────────────────────────────────────────────────────────
# OpenTelemetry — leave empty to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hermes

# ── AI features (optional) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ENABLE_AI_FEATURES=false

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_SIMULATOR=true
ENABLE_JS_TRANSFORMS=false     # requires Deno in worker image
