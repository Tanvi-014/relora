# ── Hermes v2 Environment Configuration ────────────────────────────────────
# Copy to .env and fill in values before running.

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Hermes Webhook Middleware
ENVIRONMENT=development              # development | production
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hermes:hermesdev@localhost:5432/hermes
SYNC_DATABASE_URL=postgresql://hermes:hermesdev@localhost:5432/hermes
POSTGRES_PASSWORD=hermesdev

# DB connection pool (production tuning)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Worker ───────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
WORKER_POLL_INTERVAL_SECONDS=1.0
DEFAULT_MAX_RETRIES=5
HTTP_CLIENT_TIMEOUT_SECONDS=10.0
BACKOFF_BASE_SECONDS=30

# ── Security ─────────────────────────────────────────────────────────────
# NEVER commit real secrets. Generate with: openssl rand -hex 32
JWT_SECRET=change-this-secret-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

# Cookie security (set true in production with HTTPS)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# HTTPS enforcement
FORCE_HTTPS=false

# ── API Keys (legacy / programmatic access) ───────────────────────────────
# Leave empty for local dev. Set in production to require X-Hermes-API-Key.
HERMES_API_KEY=
# Multi-tenant: tenant_a:key_a,tenant_b:key_b
HERMES_API_KEYS=

# ── Destination validation ────────────────────────────────────────────────
# MUST be false in production. true only for local Docker demos.
ALLOW_PRIVATE_DESTINATIONS=true
# Optional comma-separated allowlist: api.example.com,webhooks.example.com
DESTINATION_HOST_ALLOWLIST=

# ── Webhook signature verification ───────────────────────────────────────
STRIPE_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
HERMES_WEBHOOK_SECRET=
SIGNATURE_TOLERANCE_SECONDS=300

# Standard Webhooks outbound signing secret (whsec_ prefixed base64)
STANDARD_WEBHOOKS_SECRET=

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Schema management ─────────────────────────────────────────────────────
# false in production — use alembic upgrade head instead
AUTO_CREATE_TABLES=false

# ── AI features (optional) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
ENABLE_AI_FEATURES=false

# ── Feature flags ────────────────────────────────────────────────────────
ENABLE_SIMULATOR=true
ENABLE_JS_TRANSFORMS=false     # requires Deno in worker image
