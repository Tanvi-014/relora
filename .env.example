APP_NAME=Hermes Webhook Middleware
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hermes
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hermes

WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_SECONDS=1.0
DEFAULT_MAX_RETRIES=5
HTTP_CLIENT_TIMEOUT_SECONDS=5.0
BACKOFF_BASE_SECONDS=30

# Leave empty for local demo mode. Set in production to require X-Hermes-API-Key.
HERMES_API_KEY=

# Optional comma-separated tenant API keys: tenant_a:key_a,tenant_b:key_b
HERMES_API_KEYS=

# Local demos often target localhost or host.docker.internal. Set false in production.
ALLOW_PRIVATE_DESTINATIONS=true

# Optional comma-separated host allowlist, for example: api.example.com,webhooks.example.com
DESTINATION_HOST_ALLOWLIST=

# Optional provider webhook secrets for signature verification.
STRIPE_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=
HERMES_WEBHOOK_SECRET=
SIGNATURE_TOLERANCE_SECONDS=300

# Keep true for the MVP/demo path. Production deployments should use migrations.
AUTO_CREATE_TABLES=true
